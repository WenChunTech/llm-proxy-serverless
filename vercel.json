{
  "framework": null,
  "bunVersion": "1.x",
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "functions": {
    "api/index.js": {
      "includeFiles": "{api,pkg,public}/**"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/v1/(.*)", "destination": "/api/index.js" },
    { "source": "/v1beta/(.*)", "destination": "/api/index.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" }
  ],
  "git": {
    "deploymentEnabled": {
      "deno": false,
      "cloudflare": true
    }
  },
  "crons": [
    {
      "path": "/api/refresh-tokens",
      "schedule": "0 1 * * *"
    }
  ]
}
